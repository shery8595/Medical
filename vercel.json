{
    "buildCommand": "npm run build:prebuilt",
    "rewrites": [
        {
            "source": "/api/relayer/11155111/v2",
            "destination": "https://relayer.testnet.zama.org/v2"
        },
        {
            "source": "/api/relayer/11155111/v2/:path*",
            "destination": "https://relayer.testnet.zama.org/v2/:path*"
        },
        {
            "source": "/indexer/:path*",
            "destination": "https://indexermedvault-production.up.railway.app/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
