FAUCET_PRIVATE_KEY=0x...
# Optional — MUST be Arbitrum Sepolia (421614), NOT eth-sepolia (Ethereum Sepolia).
# Default if unset: https://sepolia-rollup.arbitrum.io/rpc
# Alchemy example: https://arb-sepolia.g.alchemy.com/v2/<KEY>
# ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# PORT=8787
# DRIP_ETH=0.0004
# COOLDOWN_MS=86400000
# MAX_DRIPS_PER_WINDOW=3
# Production: exact browser origin of your dapp (no trailing slash)
# No trailing slash — must match the browser origin exactly
# FAUCET_CORS_ORIGIN=https://med-vault.xyz
